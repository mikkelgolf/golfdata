# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# pdftotext intermediate output (regenerated by scripts/build-records.ts)
/scripts/records-raw/

# daily-refresh pipeline (scripts/daily-refresh.sh)
/data/clippd/tournaments-*.json
/data/clippd/rankings-men-*.ts
/data/clippd/rankings-women-*.ts
/logs/
/.daily-refresh-disabled

# team-deep-dive pipeline — intermediates and scraper caches are regenerated
/data/team-deep-dive/
/data/cache/
# School record-book PDFs are bulky source data (one is >100MB); keep local only
/data/source/*-record-book-*.pdf
/data/source/*-media-guide-*.pdf
# Built record-book outputs are large; revisit storage strategy before tracking
/src/data/teams/
/src/data/events/
/src/data/players/
__pycache__/
